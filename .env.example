# ─────────────────────────────────────────────────────────────────────
# odoo-docker-nginx-proxy — environment template
#
# Copy to `.env` and fill in real values. Never commit `.env`.
# Every variable here is consumed by docker-compose.yml or one of the
# config files under ./config.
# ─────────────────────────────────────────────────────────────────────

# ─── General ──────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=odoo
TZ=UTC

# ─── Public-facing ────────────────────────────────────────────────────
# Domain Nginx will serve and request TLS certificates for.
DOMAIN=odoo.example.com
# Email used by Let's Encrypt / certbot if you wire it in.
ACME_EMAIL=admin@example.com

# ─── Odoo ─────────────────────────────────────────────────────────────
# Default supported version is Odoo 18.0. This is the only version the
# stack is tested against. See README.md → "Switching Odoo versions"
# before changing this — a major-version bump is a database migration,
# not a config tweak. Other majors (e.g. 17.0, 19.0) are not the target
# of this repository.
ODOO_VERSION=18.0
# Full image reference. Override this if you need a different registry,
# a vendored image, or a pinned digest (recommended for production).
#   Example pinned: ODOO_IMAGE=odoo@sha256:<digest>
ODOO_IMAGE=odoo:${ODOO_VERSION}

# Master password protecting the database manager (/web/database/*).
# MUST be long and random. Generate with: openssl rand -base64 32
ODOO_ADMIN_PASSWD=change-me-to-a-32-char-random-string
# Number of HTTP workers. Rule of thumb: (2 × CPU cores) + 1.
WORKERS=3
# Longpolling port (used by chat / bus). Nginx proxies websockets here.
LONGPOLLING_PORT=8072

# ─── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_VERSION=16
POSTGRES_DB=postgres
POSTGRES_USER=odoo
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=change-me-to-a-32-char-random-string
# Volume name for the PG data directory. Rename to migrate between
# major versions safely.
POSTGRES_VOLUME=odoo-pgdata

# ─── PgBouncer ────────────────────────────────────────────────────────
# Image tag for the pgbouncer container.
#
# Tag format is `v<upstream-version>-p<patch>` where <patch> is the
# image author's own packaging revision (not an upstream PgBouncer
# release). Browse available tags:
#   https://hub.docker.com/r/edoburu/pgbouncer/tags
PGBOUNCER_VERSION=v1.25.1-p0
#
# Pool sizing and timeouts are NOT env-driven — they live in
# pgbouncer/pgbouncer.ini. PgBouncer does not perform env-var
# substitution in its config file, so tuning is "edit the .ini and
# reload". See docs/pgbouncer.md → "Tuning".

# ─── Odoo → DB routing ────────────────────────────────────────────────
# Defaults route Odoo through PgBouncer. Override to bypass the pool
# (e.g. for debugging, migrations, or workloads that need session-mode
# Postgres features like LISTEN/NOTIFY across requests).
#
#   ODOO_DB_HOST=db     ODOO_DB_PORT=5432   # bypass — direct to Postgres
#   ODOO_DB_HOST=pgbouncer  ODOO_DB_PORT=6432   # pooled (default)
ODOO_DB_HOST=pgbouncer
ODOO_DB_PORT=6432

# ─── Nginx ────────────────────────────────────────────────────────────
# Image tag for the nginx container.
NGINX_VERSION=1.27
# Host ports published by nginx. Change if 80/443 are already in use
# on this machine (e.g. NGINX_HTTP_PORT=8080, NGINX_HTTPS_PORT=8443).
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
# Paths inside the Nginx container. Mount real certs over these.
# See nginx/certs/README.md for how to provision them.
NGINX_SSL_CERT=/etc/nginx/certs/fullchain.pem
NGINX_SSL_KEY=/etc/nginx/certs/privkey.pem
# Max request body size (Odoo uploads, attachments). Edit
# client_max_body_size in nginx/conf.d/odoo.conf to match if changed.
NGINX_CLIENT_MAX_BODY_SIZE=200M
