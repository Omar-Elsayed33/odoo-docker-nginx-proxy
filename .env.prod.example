# ─────────────────────────────────────────────────────────────────────
# .env.prod.example — production environment template
#
# Copy to `.env` on your PRODUCTION server (NOT on your laptop) and
# edit the placeholder values. Never commit the real `.env`.
#
# This file differs from .env.example in the values that matter for
# production: real domain, stronger sizing, and the COMPOSE_FILE line
# that auto-loads the production overrides.
# ─────────────────────────────────────────────────────────────────────

# ─── Compose orchestration ────────────────────────────────────────────
# Auto-load production overrides. With this set, plain `docker compose`
# (and every scripts/ wrapper) applies docker-compose.prod.yml on top
# of the base file automatically.
COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
COMPOSE_PROJECT_NAME=odoo

# ─── General ──────────────────────────────────────────────────────────
TZ=UTC

# ─── Public-facing ────────────────────────────────────────────────────
DOMAIN=odoo.example.com
ACME_EMAIL=ops@example.com

# ─── Odoo ─────────────────────────────────────────────────────────────
ODOO_VERSION=18.0
ODOO_IMAGE=odoo:${ODOO_VERSION}
# Generate with:  openssl rand -base64 32 | tr -d '\n/+=' | cut -c1-40
ODOO_ADMIN_PASSWD=REPLACE_WITH_OPENSSL_RAND
# (2 × CPU cores) + 1 is a reasonable starting point. Tune from
# `SHOW POOLS;` queueing on pgbouncer and worker CPU saturation.
WORKERS=9
LONGPOLLING_PORT=8072

# Odoo container resource caps (overrides in docker-compose.prod.yml).
# Reservations are per-service; limits are per-service.
ODOO_CPUS=4
ODOO_MEMORY=4g

# ─── Odoo → DB routing ────────────────────────────────────────────────
ODOO_DB_HOST=pgbouncer
ODOO_DB_PORT=6432

# ─── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_VERSION=16
POSTGRES_DB=postgres
POSTGRES_USER=odoo
# Generate with:  openssl rand -base64 32 | tr -d '\n/+=' | cut -c1-40
POSTGRES_PASSWORD=REPLACE_WITH_OPENSSL_RAND
POSTGRES_VOLUME=odoo-prod-pgdata
POSTGRES_CPUS=2
POSTGRES_MEMORY=2g

# ─── PgBouncer ────────────────────────────────────────────────────────
PGBOUNCER_VERSION=v1.25.1-p0
PGBOUNCER_CPUS=0.5
PGBOUNCER_MEMORY=128m

# ─── Nginx ────────────────────────────────────────────────────────────
NGINX_VERSION=1.27
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_SSL_CERT=/etc/nginx/certs/fullchain.pem
NGINX_SSL_KEY=/etc/nginx/certs/privkey.pem
NGINX_CLIENT_MAX_BODY_SIZE=200M
NGINX_CPUS=1
NGINX_MEMORY=256m
