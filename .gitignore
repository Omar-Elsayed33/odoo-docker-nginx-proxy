# ─────────────────────────────────────────────────────────────────────
# .gitignore — odoo-docker-nginx-proxy
#
# Policy:
#   - Ignore anything secret, generated, machine-specific, or runtime.
#   - Keep tracked: source, documentation, *.example templates, and
#     .gitkeep directory placeholders.
#
# Rule of thumb: a file accidentally committed is much harder to
# remove than one accidentally left local. When in doubt, ignore.
# ─────────────────────────────────────────────────────────────────────

# ─── Environment files (highest risk: contain real secrets) ──────────
.env
.env.*
!.env.example                    # tracked template — never put real secrets here

# ─── TLS / cryptographic material ────────────────────────────────────
*.pem
*.key
*.crt
*.cer
*.csr
*.p12
*.pfx
*.jks
secrets/

# ─── Generated credential files ──────────────────────────────────────
pgbouncer/userlist.txt

# ─── Container runtime data (must never be committed) ────────────────
# Named Docker volumes live outside this repo, but bind mounts pointed
# at any of these paths would populate the working tree on `up`.
data/
volumes/
postgres-data/
postgres/data/
odoo-data/
odoo/data/
odoo/filestore/
.docker/

# ─── Backups & database dumps ────────────────────────────────────────
# Plain *.sql files are intentionally NOT ignored — they're usually
# source (migrations, init scripts). Only compressed / dump artefacts
# match here.
backups/
*.dump
*.sql.gz
*.sql.bz2
*.bak
*.tmp
*.temp

# ─── Logs ────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ─── Local Compose overrides (machine-specific) ──────────────────────
docker-compose.override.yml
docker-compose.override.yaml
compose.override.yml
compose.override.yaml
docker-compose.*.local.yml
docker-compose.*.local.yaml

# ─── Python (custom Odoo addons) ─────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.venv/
venv/
env/

# ─── Node (frontend tooling, if any lands in addons) ─────────────────
node_modules/
dist/
.parcel-cache/

# ─── Editor / IDE ────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# ─── Operating system ────────────────────────────────────────────────
.DS_Store
._*
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ─── Shell / direnv ──────────────────────────────────────────────────
.direnv/
.envrc

# ─── Defensive guards — always tracked, regardless of rules above ────
# Last-match-wins, so these negations override any broader pattern
# that might later be added. Examples, gitkeep placeholders, and
# in-repo documentation must never be ignored.
!*.example
!**/.gitkeep
!**/README.md
